    {
      "name": "08 - Payment (PayOS)",
      "item": [
        {
          "name": "Create PayOS payment link (captures checkoutUrl)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "const url = json?.data?.checkoutUrl || json?.data?.paymentUrl || json?.data?.url;",
                  "if (url) pm.collectionVariables.set('checkoutUrl', url);",
                  "const pid = json?.data?.paymentId || json?.data?.id || json?.data?._id;",
                  "if (pid) pm.collectionVariables.set('paymentId', pid);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payment/payos/create",
              "protocol": "http",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
