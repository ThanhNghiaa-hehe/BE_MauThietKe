            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{randomEmail}}\",\n  \"password\": \"123456\",\n  \"fullname\": \"Student One\",\n  \"phoneNumber\": \"0123456789\"\n}"
