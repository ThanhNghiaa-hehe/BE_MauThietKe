      "item": [
        {
          "name": "Register (captures otpToken + loginEmail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "const otpToken = json?.data?.token || json?.data?.otpToken || json?.token;",
                  "if (otpToken) pm.collectionVariables.set('otpToken', otpToken);",
                  "",
                  "try {",
                  "  const body = pm.request.body?.raw ? JSON.parse(pm.request.body.raw) : null;",
                  "  if (body?.email) pm.collectionVariables.set('loginEmail', body.email);",
                  "} catch (e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "protocol": "http",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
