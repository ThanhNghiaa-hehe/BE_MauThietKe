  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Generate random email once per run",
          "if (!pm.collectionVariables.get('randomEmail')) {",
          "  const ts = Date.now();",
          "  pm.collectionVariables.set('randomEmail', `student_${ts}@example.com`);",
          "}",
          "",
          "// Auto attach USER token if present",
          "const token = pm.collectionVariables.get('token');",
          "if (token && token.trim()) {",
          "  pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
